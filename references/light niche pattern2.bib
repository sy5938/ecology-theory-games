@article{kraftFunctionalTraitsNichebased2008,
  title = {Functional Traits and Niche-Based Tree Community Assembly in an {{Amazonian}} Forest},
  author = {Kraft, Nathan J. B. and Valencia, Renato and Ackerly, David D.},
  date = {2008},
