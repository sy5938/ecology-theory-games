@article{kupersPerformanceTropicalForest2019,
  title = {Performance of Tropical Forest Seedlings under Shade and Drought: An Interspecific Trade-off in Demographic Responses},
  shorttitle = {Performance of Tropical Forest Seedlings under Shade and Drought},
  author = {Kupers, Stefan J. and Wirth, Christian and Engelbrecht, Bettina M. J. and Hernández, Andrés and Condit, Richard and Wright, S. Joseph and Rüger, Nadja},
  date = {2019-12-11},
